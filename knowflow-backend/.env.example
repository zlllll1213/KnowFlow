# ============================================================
# KnowFlow 后端环境变量
# 复制此文件为 .env 并修改实际值
# docker compose --env-file .env up -d
# ============================================================

# PostgreSQL
POSTGRES_DB=knowflow
POSTGRES_USER=knowflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Spring Boot runtime
KNOWFLOW_RAG_BASE_URL=http://localhost:8090
KNOWFLOW_RAG_CONNECT_TIMEOUT_MS=3000
KNOWFLOW_RAG_READ_TIMEOUT_MS=120000
KNOWFLOW_RAG_MOCK_FALLBACK_ENABLED=false
