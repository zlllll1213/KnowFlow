# ============================================================
# KnowFlow Python Worker 环境变量
# 复制为 .env 并修改
# ============================================================

# Redis 任务队列
WORKER_REDIS_URL=redis://localhost:6379/0

# PostgreSQL
WORKER_DB_HOST=localhost
WORKER_DB_PORT=5432
WORKER_DB_NAME=knowflow
WORKER_DB_USER=knowflow
WORKER_DB_PASSWORD=knowflow123

# MinIO（用于下载原始文件）
WORKER_MINIO_ENDPOINT=localhost:9000
WORKER_MINIO_ACCESS_KEY=minioadmin
WORKER_MINIO_SECRET_KEY=minioadmin123
WORKER_MINIO_BUCKET=knowflow
WORKER_MINIO_SECURE=false

# 本地文件存储（storage.type=local 时使用）
WORKER_STORAGE_TYPE=local
WORKER_STORAGE_LOCAL_PATH=../knowflow-backend/storage

# Embedding
WORKER_EMBEDDING_PROVIDER=mock
WORKER_EMBEDDING_API_KEY=
WORKER_EMBEDDING_MODEL=text-embedding-3-small
WORKER_EMBEDDING_DIM=1536
WORKER_EMBEDDING_BASE_URL=

# 切片参数
WORKER_CHUNK_SIZE=512
WORKER_CHUNK_OVERLAP=64
WORKER_MAX_CHUNKS_PER_DOC=1000

# Worker 并发数
WORKER_CONCURRENCY=2

# 日志级别
WORKER_LOG_LEVEL=INFO
