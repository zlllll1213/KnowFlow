# ============================================================
# KnowFlow Go RAG Service 环境变量
# 复制为 .env 并修改
# ============================================================

RAG_PORT=8090
RAG_DB_DSN=postgres://knowflow:change_me@localhost:5432/knowflow?sslmode=disable
RAG_REQUEST_TIMEOUT_SECONDS=60

# 检索参数
RAG_DEFAULT_TOP_K=5
RAG_MAX_TOP_K=20

# LLM: mock / deepseek / openai / ollama
RAG_LLM_PROVIDER=mock
# DeepSeek 示例（不要提交真实 key）：
# RAG_LLM_PROVIDER=deepseek
# RAG_LLM_API_KEY=sk-...
# RAG_LLM_BASE_URL=https://api.deepseek.com
# RAG_LLM_MODEL=deepseek-v4-flash
# RAG_LLM_THINKING_ENABLED=false
RAG_LLM_API_KEY=
RAG_LLM_BASE_URL=
RAG_LLM_MODEL=
RAG_LLM_THINKING_ENABLED=false

# Embedding: mock / openai / ollama
# mock 会走关键词检索；配置真实 provider 后会优先使用 pgvector 向量检索
# Embedding Key 不会继承 LLM Key；DeepSeek 暂不作为 embedding provider。
RAG_EMBEDDING_PROVIDER=mock
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
