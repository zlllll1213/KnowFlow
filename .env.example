# ============================================================
# KnowFlow 项目根环境变量示例
# 复制为 .env 并根据实际情况修改
# ============================================================

# --- 后端 Spring Boot ---
# 数据库
KNOWFLOW_DB_HOST=localhost
KNOWFLOW_DB_PORT=5432
KNOWFLOW_DB_NAME=knowflow
KNOWFLOW_DB_USER=knowflow
KNOWFLOW_DB_PASSWORD=change_me_in_production

# Redis
KNOWFLOW_REDIS_HOST=localhost
KNOWFLOW_REDIS_PORT=6379

# JWT
KNOWFLOW_JWT_SECRET=change_me_to_a_random_256bit_string
KNOWFLOW_JWT_EXPIRATION_MS=86400000

# MinIO
KNOWFLOW_MINIO_ENDPOINT=http://localhost:9000
KNOWFLOW_MINIO_ACCESS_KEY=minioadmin
KNOWFLOW_MINIO_SECRET_KEY=change_me_in_production
KNOWFLOW_MINIO_BUCKET=knowflow

# 文件存储（local / minio）
KNOWFLOW_STORAGE_TYPE=local
KNOWFLOW_STORAGE_LOCAL_PATH=./storage

# Go RAG Service
KNOWFLOW_RAG_BASE_URL=http://localhost:8090
KNOWFLOW_RAG_CONNECT_TIMEOUT_MS=3000
KNOWFLOW_RAG_READ_TIMEOUT_MS=120000
# dev 可设为 true，prod 必须保持 false，避免 Go RAG 不可用时返回 mock 答案
KNOWFLOW_RAG_FALLBACK_ENABLED=false

# --- Python Worker ---
WORKER_REDIS_URL=redis://localhost:6379/0
WORKER_DB_DSN=postgresql://knowflow:change_me@localhost:5432/knowflow
WORKER_MINIO_ENDPOINT=localhost:9000
WORKER_MINIO_ACCESS_KEY=minioadmin
WORKER_MINIO_SECRET_KEY=change_me
WORKER_MINIO_BUCKET=knowflow
WORKER_EMBEDDING_PROVIDER=mock
WORKER_EMBEDDING_API_KEY=
WORKER_EMBEDDING_BASE_URL=
WORKER_EMBEDDING_MODEL=text-embedding-3-small
WORKER_EMBEDDING_DIM=1536
WORKER_EMBEDDING_BATCH_SIZE=32
WORKER_EMBEDDING_TIMEOUT_SECONDS=60
WORKER_CONCURRENCY=2
WORKER_TASK_RECOVERY_INTERVAL_SECONDS=60

# --- Go RAG Service ---
RAG_PORT=8090
RAG_DB_DSN=postgres://knowflow:change_me@localhost:5432/knowflow?sslmode=disable
RAG_REQUEST_TIMEOUT_SECONDS=60
RAG_LLM_PROVIDER=mock
RAG_LLM_API_KEY=
RAG_LLM_BASE_URL=
RAG_LLM_MODEL=
RAG_EMBEDDING_PROVIDER=mock
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_DEFAULT_TOP_K=5
RAG_MAX_TOP_K=20
